rules_version = '2';
service firebase.storage {
  match /b/{bucket}/o {
    function signedIn() { return request.auth != null; }
    function isManager() {
      return signedIn() &&
        firestore.get(/databases/(default)/documents/staff/$(request.auth.uid)).data.role == "manager";
    }

    match /submissions/{date}/{uid}/{taskId}/{fileName} {
      allow read: if signedIn() && (uid == request.auth.uid || isManager());
      allow write: if signedIn() && uid == request.auth.uid;
      allow delete: if isManager();
    }
  }
}
